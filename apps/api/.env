APP_NAME=Hydro Flood API
ENV=dev
DATABASE_URL=postgresql+psycopg2://hydro:hydro@postgres:5432/hydro
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data/storage
WORKSPACE_ROOT=/data/workspaces
MAX_UPLOAD_MB=100
USE_MOCK_RAS=false
WORKER_HEARTBEAT_PATH=/data/worker/hecras-worker.json
WORKER_HEARTBEAT_MAX_AGE_SECONDS=120
